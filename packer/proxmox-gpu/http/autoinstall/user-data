#cloud-config
# GPU node autoinstall — identical to base Ubuntu template.
# The GPU-specific packages are installed by provision-gpu-node.sh,
# not during the OS installation phase.
autoinstall:
  version: 1
  interactive-sections: []

  locale: en_GB.UTF-8
  keyboard:
    layout: gb

  network:
    network:
      version: 2
      ethernets:
        id0:
          match:
            name: "en*"
          dhcp4: true

  storage:
    layout:
      name: lvm
      sizing-policy: all

  identity:
    hostname: k8s-gpu-template
    username: packer
    password: "$6$randomsalt$Y9I6baU6/XBXbwHqL9WqhUxEtpn068Ssu.yflHxMZNsO9tIi1ARi9m1vhY8szl1bF.So//IYQx378cx9SFCDF/"

  ssh:
    install-server: true
    allow-pw: true

  packages:
    - qemu-guest-agent
    - cloud-init
    # Build tools needed for NVIDIA DKMS kernel module compilation
    - build-essential
    - linux-headers-generic

  late-commands:
    - echo 'packer ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/packer
    - chmod 440 /target/etc/sudoers.d/packer
    - systemctl enable qemu-guest-agent --root=/target