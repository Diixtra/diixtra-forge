{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  // ═══════════════════════════════════════════════════════════════
  // LEARNING NOTE — WHAT RENOVATE DOES:
  //   Renovate is a GitHub bot (or self-hosted app) that scans your
  //   repo for dependency declarations and creates PRs when updates
  //   are available. It understands 50+ package formats including:
  //     - Helm chart versions in Flux HelmRelease CRDs
  //     - Docker image tags in Kubernetes manifests
  //     - GitHub Actions versions in .github/workflows/
  //     - Terraform provider versions
  //     - npm/pip/cargo dependencies
  //
  //   For a lab, we configure it to auto-merge everything without
  //   review. In production, you'd require approval.
  // ═══════════════════════════════════════════════════════════════

  // Start with the recommended base config, then override for lab use
  "extends": [
    "config:recommended",
    ":automergeAll",
    ":automergePatch",
    ":automergeMinor"
  ],

  // ── Lab-specific: auto-merge EVERYTHING without review ────────
  // Remove these two lines if you ever want PR reviews back.
  "automerge": true,
  "automergeType": "pr",

  // ── Flux / Kubernetes-specific managers ────────────────────────
  // Renovate has built-in support for Flux CRDs. It understands
  // HelmRelease, HelmRepository, GitRepository, OCIRepository,
  // and image references in Kustomize overlays.
  "flux": {
    "fileMatch": [
      "(^|/)clusters/.+\\.ya?ml$",
      "(^|/)infrastructure/.+\\.ya?ml$",
      "(^|/)platform/.+\\.ya?ml$",
      "(^|/)apps/.+\\.ya?ml$"
    ]
  },

  // ── Container image updates in Kubernetes manifests ───────────
  "kubernetes": {
    "fileMatch": [
      "(^|/)infrastructure/.+\\.ya?ml$",
      "(^|/)platform/.+\\.ya?ml$",
      "(^|/)apps/.+\\.ya?ml$"
    ]
  },

  // ── GitHub Actions version updates ────────────────────────────
  "github-actions": {
    "fileMatch": [
      "^.github/workflows/[^/]+\\.ya?ml$"
    ]
  },

  // ── Terraform provider and module updates ─────────────────────
  "terraform": {
    "fileMatch": [
      "(^|/)terraform/.+\\.tf$"
    ]
  },

  // ── Schedule: run every 6 hours ───────────────────────────────
  // Default is "before 5am on Monday" which is too infrequent for a lab.
  "schedule": [
    "every 6 hours"
  ],

  // ── Group related updates into single PRs ─────────────────────
  // Instead of 10 separate PRs for 10 minor updates, group them.
  "packageRules": [
    {
      // Group all Flux controller updates together
      "matchPackagePatterns": ["^ghcr.io/fluxcd/"],
      "groupName": "Flux controllers",
      "automerge": true
    },
    {
      // Group all GitHub Actions updates together
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": true
    },
    {
      // Group all Terraform provider updates together
      "matchManagers": ["terraform"],
      "groupName": "Terraform providers",
      "automerge": true
    },
    {
      // Group Helm chart patch updates (safety in numbers)
      "matchManagers": ["flux"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "Helm charts",
      "automerge": true
    }
  ],

  // ── PR settings ───────────────────────────────────────────────
  "prHourlyLimit": 10,
  "prConcurrentLimit": 5,

  // ── Commit message format ─────────────────────────────────────
  "commitMessagePrefix": "chore(deps):"
}
